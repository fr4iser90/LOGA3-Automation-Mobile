# LOGA3 Mobile — Env Example
# Kopieren: cp .env.example .env  (nicht committen)

# LOGA3 Tenant-URL (Pflicht für Live-Fetch) — kein Default im Code
# EXPO_PUBLIC_LOGA3_URL=https://YOUR-TENANT.example/loga3/#

# Google OAuth (Mobile clients — nicht der Desktop Web-Client)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
