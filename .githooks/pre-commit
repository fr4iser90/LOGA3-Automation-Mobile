#!/usr/bin/env bash
# Fast local guard — enable with: git config core.hooksPath .githooks
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

staged="$(git diff --cached --name-only --diff-filter=ACM)"

if [[ -z "${staged}" ]]; then
  exit 0
fi

blocked=0
while IFS= read -r f; do
  [[ -z "$f" ]] && continue
  base="$(basename "$f")"

  if [[ "$base" == .env || "$base" == .env.* ]]; then
    if [[ "$base" != .env.example ]]; then
      echo "pre-commit: refuse staged secret file: $f" >&2
      blocked=1
    fi
  fi

  if [[ "$f" == node_modules || "$f" == node_modules/* || "$f" == */node_modules || "$f" == */node_modules/* ]]; then
    echo "pre-commit: refuse staged node_modules path: $f" >&2
    blocked=1
  fi

  if [[ "$base" == *.keystore || "$base" == *.jks || "$base" == credentials.json ]] \
    || [[ "$base" == *service-account*.json ]]; then
    echo "pre-commit: refuse staged credential/keystore: $f" >&2
    blocked=1
  fi
done <<< "$staged"

if [[ "$blocked" -ne 0 ]]; then
  exit 1
fi

# Soft secret pattern scan on staged diff (not perfect)
if git diff --cached -U0 | grep -Eiq \
  '(api[_-]?key\s*=\s*['\''\"]?[a-z0-9]{20,}|AKIA[0-9A-Z]{16}|-----BEGIN (RSA |OPENSSH )?PRIVATE KEY-----)'; then
  echo "pre-commit: staged diff looks like it contains a secret pattern — abort." >&2
  echo "  If false positive: fix the hunk or commit with care after review." >&2
  exit 1
fi

# lockfile changed → quick high+ audit
if echo "$staged" | grep -Eq '^(package-lock\.json|package\.json)$'; then
  if [[ -d node_modules ]] && command -v npm >/dev/null 2>&1; then
    echo "pre-commit: package.json/lock staged → npm audit --audit-level=high"
    npm audit --audit-level=high
  else
    echo "pre-commit: skip npm audit (run npm ci locally / rely on CI)"
  fi
fi

exit 0
